# Google Earth Engine
GEE_PROJECT=your-gee-project-id

# Optional: Service account JSON as single-line JSON string
# Do not commit real credentials
GEE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# Optional: SMTP alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=alerts@example.com
SMTP_PASS=app-password
